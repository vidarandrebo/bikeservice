{
    "name": "bikeservice-client",
    "version": "4.1.0",
    "private": true,
    "author": {
        "name": "Vidar André Bø"
    },
    "type": "module",
    "scripts": {
        "dev": "vite",
        "buildDev": "vue-tsc && vite build --mode development",
        "build": "vue-tsc && vite build",
        "preview": "vite preview",
        "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
        "lint-fix": "eslint . --report-unused-disable-directives --max-warnings 0 --fix",
        "format": "prettier . --write",
        "generate": "npm run openapi && npm run lint-fix && npm run format",
        "openapi": "openapi-generator-cli generate -i ../../BikeService.Server.json -g typescript-fetch -o src/Gen/ --additional-properties=withInterfaces=true",
        "test": "vitest run"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@fortawesome/fontawesome-svg-core": "^7.2.0",
        "@fortawesome/free-regular-svg-icons": "^7.2.0",
        "@fortawesome/free-solid-svg-icons": "^7.2.0",
        "@fortawesome/vue-fontawesome": "^3.2.0",
        "@openapitools/openapi-generator-cli": "^2.32.0",
        "@typescript-eslint/eslint-plugin": "^8.59.3",
        "@typescript-eslint/parser": "^8.59.3",
        "@vitejs/plugin-vue": "^6.0.7",
        "buefy": "^3.0.7",
        "bulma": "^1.0.4",
        "eslint": "^10.4.0",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-vue": "^10.9.1",
        "globals": "^17.6.0",
        "prettier": "^3.8.3",
        "sass": "^1.99.0",
        "typescript": "~6.0.3",
        "typescript-eslint": "^8.59.3",
        "vite": "^8.0.13",
        "vitest": "^4.1.6",
        "vue": "^3.5.34",
        "vue-router": "^5.0.7",
        "vue-tsc": "^3.2.9"
    },
    "packageManager": "pnpm@11.1.3+sha512.c85357fe17ca12dd23dd7071822666dfd7e3cb76fe214e3370b5ea2fb34f2a231185509b63e717f3cd0acb38dd3f8d82bcd5e8172400ae678b70ea4fbed0896d"
}
