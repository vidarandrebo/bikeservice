{
    "name": "bikeservice-client",
    "version": "4.1.0",
    "private": true,
    "author": {
        "name": "Vidar André Bø"
    },
    "type": "module",
    "scripts": {
        "dev": "vite",
        "buildDev": "vue-tsc && vite build --mode development",
        "build": "vue-tsc && vite build",
        "preview": "vite preview",
        "lint": "eslint . --report-unused-disable-directives --max-warnings 0",
        "lint-fix": "eslint . --report-unused-disable-directives --max-warnings 0 --fix",
        "format": "prettier . --write",
        "generate": "npm run openapi && npm run lint-fix && npm run format",
        "openapi": "openapi-generator-cli generate -i ../../BikeService.Server.json -g typescript-fetch -o src/Gen/ --additional-properties=withInterfaces=true",
        "test": "vitest run"
    },
    "devDependencies": {
        "@fortawesome/fontawesome-svg-core": "^7.2.0",
        "@fortawesome/free-regular-svg-icons": "^7.2.0",
        "@fortawesome/free-solid-svg-icons": "^7.2.0",
        "@fortawesome/vue-fontawesome": "^3.1.3",
        "@openapitools/openapi-generator-cli": "^2.29.0",
        "@typescript-eslint/eslint-plugin": "^8.56.0",
        "@typescript-eslint/parser": "^8.56.0",
        "@vitejs/plugin-vue": "^6.0.4",
        "buefy": "^3.0.4",
        "eslint": "^10.0.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-vue": "^10.8.0",
        "globals": "^17.3.0",
        "prettier": "^3.8.1",
        "sass": "^1.97.3",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.56.0",
        "vite": "^7.3.1",
        "vitest": "^4.0.18",
        "vue": "^3.5.28",
        "vue-router": "^5.0.3",
        "vue-tsc": "^3.2.4"
    }
}
